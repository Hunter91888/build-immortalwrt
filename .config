# 目标平台：高通MSM8916（粤百讯410对应UFI003）
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_msm8916=y
CONFIG_TARGET_qualcommax_msm8916_DEVICE_ufi003=y

# 开启CDC-ECM（苹果免驱），彻底关闭RNDIS（Windows用）
CONFIG_KERNEL_USB_GADGET=y
CONFIG_KERNEL_USB_GADGET_ECM=y
# CONFIG_KERNEL_USB_GADGET_RNDIS is not set
# CONFIG_KERNEL_USB_GADGET_MBIM is not set
CONFIG_PACKAGE_kmod-usb-gadget=y
CONFIG_PACKAGE_kmod-usb-gadget-ecm=y
# CONFIG_PACKAGE_kmod-usb-gadget-rndis is not set
CONFIG_PACKAGE_kmod-usb-lib-composite=y
